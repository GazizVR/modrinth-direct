{
	"schemaVersion": 1,
	"id": "modrinth-direct",
	"version": "${version}",
	"name": "Modrinth Direct",
	"description": "Automates mod discovery and installation using the Modrinth API.",
	"authors": [
		"gaziz"
	],
	"contact": {
		"sources": "https://github.com/GazizVR/modrinth-direct"
	},
	"license": "MIT",
	"icon": "assets/modrinth-direct/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			{
				"value": "org.gaziz.modrinthdirect.ModrinthDirect",
				"adapter": "kotlin"
			}
		],
		"client": [
			{
				"value": "org.gaziz.modrinthdirect.client.ModrinthDirectClient",
				"adapter": "kotlin"
			}
		]
	},
	"mixins": [
		{
			"config": "modrinth-direct.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*",
		"fabric-language-kotlin": "*",
		"owo": ">=0.13.0",
		"modmenu": ">=17.0.0"
	}
}